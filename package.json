{
  "name": "ics-dmas-pi-server",
  "version": "1.1.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "ICS DMAS 統一 Pi WebSocket 伺服器（shelter / medical）",
  "main": "server/index.js",
  "scripts": {
