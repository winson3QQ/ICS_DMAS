{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "醫療組 PWA (靜態預覽)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8001", "-c-1"],
      "port": 8001,
