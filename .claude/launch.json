{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "醫療組 PWA (靜態預覽)",
      "runtimeExecutable": "/usr/local/bin/python3.13",
      "runtimeArgs": ["-m", "http.server", "8001"],
      "port": 8001,
      "cwd": "medical-pwa/public"
    },
    {
      "name": "收容組 PWA (靜態預覽)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8002", "-c-1"],
      "port": 8002,
      "cwd": "shelter-pwa/public"
    },
    {
      "name": "收容組 Pi Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js", "--unit", "shelter"],
      "port": 8766,
      "cwd": "."
    },
    {
      "name": "醫療組 Pi Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js", "--unit", "medical"],
      "port": 8776,
      "cwd": "."
    },
    {
      "name": "指揮部儀表板",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "cwd": "command-dashboard/src"
    }
  ]
}
